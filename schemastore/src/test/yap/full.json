{
  "$schema": "https://www.schemastore.org/yap.json",
  "name": "full-example",
  "description": "Project exercising every supported yap.json field",
  "buildDir": "/tmp/yap-build",
  "output": "artifacts",
  "projects": [
    { "name": "foundation-lib", "description": "core library" },
    { "name": "main-app", "install": true }
  ],
  "compressionDeb": "zstd",
  "compressionRpm": "xz",
  "signing": {
    "Enabled": true,
    "KeyPath": "/home/user/.config/yap/keys/deb.gpg",
    "KeyName": "release"
  },
  "repos": [
    {
      "name": "extra",
      "url": "https://example.com/apt",
      "suite": "jammy",
      "components": ["main", "universe"],
      "keyURL": "https://example.com/key.asc",
      "distros": ["ubuntu"],
      "gpgCheck": true
    }
  ],
  "skipDeps": ["gcc"],
  "targetArch": "arm64",
  "debugDir": "/tmp/yap-debug",
  "parallel": true,
  "sbom": true,
  "sbomFormat": "both"
}
